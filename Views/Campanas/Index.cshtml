@model List<PortalCampanas.Models.Campana>

<h2>Listado de Campañas</h2>


<form method="get" style="margin-bottom:20px;">

    <label><strong>Categoría:</strong></label>
    <select name="categoria">
        <option value="">Todas</option>
        <option value="Electro">Electro</option>
        <option value="Moda">Moda</option>
    </select>

    <label style="margin-left:15px;"><strong>Estado:</strong></label>
    <select name="estado">
        <option value="">Todos</option>
        <option value="Vigente">Vigente</option>
        <option value="Próxima">Próxima</option>
    </select>

    <button type="submit" class="btn-filtrar">Filtrar</button>

</form>

<table class="tabla">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Categoría</th>
            <th>Estado</th>
            <th>Canal</th>
            <th>Descuento</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.Nombre</td>
                <td>@c.Categoria</td>
                <td>@c.Estado</td>
                <td>@c.Canal</td>
                <td>@c.DescuentoPct %</td>

                <td>
                    <a href="/Campanas/Detalle/@c.Id" class="btn-detalle">
                        Ver Detalle
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

<style>
    .tabla {
        width: 100%;
        border-collapse: collapse;
        background: white;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .tabla th {
        background-color: #007bff;
        color: white;
        padding: 10px;
    }

    .tabla td {
        padding: 10px;
        border-bottom: 1px solid #ddd;
    }

    .tabla tr:hover {
        background-color: #f1f1f1;
    }

    .btn-detalle {
        background-color: #007bff;
        color: white;
        padding: 6px 12px;
        text-decoration: none;
        border-radius: 5px;
        font-size: 14px;
    }

    .btn-detalle:hover {
        background-color: #0056b3;
    }

  
    .btn-filtrar {
        margin-left: 15px;
        padding: 6px 12px;
        background-color: #28a745;
        color: white;
        border: none;
        border-radius: 5px;
    }

    .btn-filtrar:hover {
        background-color: #218838;
    }
</style>